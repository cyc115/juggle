#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12,<3.14"
# dependencies = ["kokoro", "sounddevice", "numpy", "flask"]
# ///
"""Talkback — local TTS service using Kokoro. CLI + HTTP server modes."""

import argparse
import sys
import threading
import time
import numpy as np
import sounddevice as sd

# ---------------------------------------------------------------------------
# Global state for cancellation
# ---------------------------------------------------------------------------
_playback_lock = threading.Lock()
_current_event: threading.Event | None = None  # set → stop


_HEADPHONE_KEYWORDS = ["WH-", "WF-", "AirPods", "Headphones", "Headset", "Buds", "PLT", "PL focus"]
_FALLBACK_DEVICE = "MacBook Pro Speakers"


def _pick_device() -> str | None:
    """Return the name of the first connected headphone output, or the MacBook speakers."""
    try:
        devices = sd.query_devices()
        for d in devices:
            if d["max_output_channels"] > 0:
                for kw in _HEADPHONE_KEYWORDS:
                    if kw.lower() in d["name"].lower():
                        return d["name"]
    except Exception:
        pass
    return _FALLBACK_DEVICE


def _try_play(audio: np.ndarray, samplerate: int, device: int | str | None) -> None:
    """Attempt to play audio on the given device; raises on failure."""
    global _current_event
    with _playback_lock:
        if _current_event is not None:
            _current_event.set()
        sd.stop()
        stop_event = threading.Event()
        _current_event = stop_event

    if audio is None or len(audio) == 0:
        return

    finished = threading.Event()

    def _callback(outdata, frames, time_info, status):
        nonlocal pos
        if stop_event.is_set():
            raise sd.CallbackAbort
        chunk = audio[pos : pos + frames]
        if len(chunk) < frames:
            outdata[: len(chunk), 0] = chunk
            outdata[len(chunk) :] = 0
            raise sd.CallbackStop
        outdata[:, 0] = chunk
        pos += frames

    pos = 0
    _MAX_RETRIES = 3
    _RETRY_DELAY = 0.5
    for attempt in range(_MAX_RETRIES):
        stream = None
        try:
            stream = sd.OutputStream(
                samplerate=samplerate,
                channels=1,
                dtype="float32",
                device=device,
                callback=_callback,
                finished_callback=finished.set,
            )
            stream.start()
            break
        except Exception as e:
            if stream is not None:
                try:
                    stream.close()
                except Exception:
                    pass
            err = str(e)
            if ("-9986" in err or "Internal PortAudio error" in err) and attempt < _MAX_RETRIES - 1:
                time.sleep(_RETRY_DELAY)
                continue
            raise
    if attempt > 0:
        print(f"[talkback] device {device!r} recovered after {attempt + 1} attempt(s)", file=sys.stderr)
    finished.wait()
    stream.stop()
    stream.close()


def _play_audio(audio: np.ndarray, samplerate: int = 24000) -> None:
    """Play audio array with device fallback chain, respecting cancellation.

    Re-detects the best output device on every call so headphone/device switches
    take effect immediately without stale state.
    """
    primary = _pick_device()
    chain: list[str | None] = [primary]
    if primary != _FALLBACK_DEVICE:
        chain.append(_FALLBACK_DEVICE)

    for dev in chain:
        try:
            _try_play(audio, samplerate, dev)
            return
        except Exception as e:
            print(f"[talkback] device {dev!r} failed ({e}), trying next...", file=sys.stderr)

    print("[talkback] ERROR: all audio devices failed", file=sys.stderr)


def cancel_playback() -> None:
    """Cancel current playback immediately."""
    global _current_event
    with _playback_lock:
        if _current_event is not None:
            _current_event.set()
        sd.stop()
        _current_event = None


# ---------------------------------------------------------------------------
# TTS engine (lazy-loaded)
# ---------------------------------------------------------------------------
_pipeline = None


def _get_pipeline():
    global _pipeline
    if _pipeline is None:
        from kokoro import KPipeline
        _pipeline = KPipeline(lang_code="a")
    return _pipeline


def synthesize(text: str, voice: str = "af_heart", speed: float = 1.0) -> np.ndarray | None:
    """Synthesize text to a numpy audio array."""
    pipe = _get_pipeline()
    chunks = []
    for _graphemes, _phonemes, audio in pipe(text, voice=voice, speed=speed):
        if audio is not None:
            chunks.append(audio)
    if not chunks:
        return None
    return np.concatenate(chunks)


def speak(text: str, voice: str = "af_heart", speed: float = 1.0) -> None:
    """Synthesize and play text. Cancels any ongoing playback first."""
    if not text.strip():
        cancel_playback()
        return
    audio = synthesize(text, voice=voice, speed=speed)
    if audio is not None:
        _play_audio(audio)


# ---------------------------------------------------------------------------
# HTTP server (Flask)
# ---------------------------------------------------------------------------

def run_server(port: int, voice: str, speed: float) -> None:
    from flask import Flask, request, jsonify

    app = Flask(__name__)

    @app.route("/health", methods=["GET"])
    def health():
        return jsonify({"status": "ok"})

    @app.route("/speak", methods=["POST"])
    def handle_speak():
        data = request.get_json(silent=True) or {}
        text = data.get("text", "")
        req_speed = data.get("speed", speed)
        req_voice = data.get("voice", voice)

        if not text.strip():
            cancel_playback()
            return jsonify({"status": "cancelled"})

        t = threading.Thread(
            target=speak,
            args=(text,),
            kwargs={"voice": req_voice, "speed": req_speed},
            daemon=True,
        )
        t.start()
        return jsonify({"status": "speaking"})

    print(f"[talkback] Loading Kokoro model...")
    _get_pipeline()
    print(f"[talkback] Listening on http://localhost:{port} (auto device)")
    app.run(host="127.0.0.1", port=port, threaded=True)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(description="Talkback TTS service")
    parser.add_argument("text", nargs="?", default=None, help="Text to speak (CLI mode)")
    parser.add_argument("--listen", type=int, default=None, metavar="PORT",
                        help="Start HTTP server on PORT (default: 18787)")
    parser.add_argument("--speed", type=float, default=1.0, help="Speech speed (default: 1.0)")
    parser.add_argument("--voice", type=str, default="af_heart", help="Voice ID (default: af_heart)")
    parser.add_argument("--list-devices", action="store_true", help="List available audio output devices and exit")
    args = parser.parse_args()

    if args.list_devices:
        print(sd.query_devices())
        sys.exit(0)

    if args.listen is not None:
        run_server(port=args.listen, voice=args.voice, speed=args.speed)
    elif args.text:
        speak(args.text, voice=args.voice, speed=args.speed)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
