#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12,<3.14"
# dependencies = ["kokoro", "sounddevice", "numpy", "flask", "pyobjc-framework-CoreAudio"]
# ///
"""Talkback — local TTS service using Kokoro. CLI + HTTP server modes."""

import argparse
import json
import os
import pathlib
import sys
import threading
import time
from datetime import datetime, timezone
import numpy as np
import sounddevice as sd

# ---------------------------------------------------------------------------
# Speak log
# ---------------------------------------------------------------------------
_LOG_PATH = pathlib.Path(
    os.environ.get("JUGGLE_TALKBACK_LOG_PATH")
    or pathlib.Path.home() / ".juggle/logs/talkback.jsonl"
)


def _log_speak(text: str, voice: str, speed: float, client_ip: str) -> None:
    try:
        _LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
        entry: dict = {
            "ts": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
            "text": text,
            "voice": voice,
            "speed": speed,
            "client_ip": client_ip,
        }
        if not text.strip():
            entry["cancelled"] = True
        with open(_LOG_PATH, "a") as f:
            f.write(json.dumps(entry) + "\n")
            f.flush()
    except Exception as e:
        print(f"[talkback] WARNING: failed to write speak log: {e}", file=sys.stderr)

# ---------------------------------------------------------------------------
# Global state for cancellation
# ---------------------------------------------------------------------------
_playback_lock = threading.Lock()
_current_event: threading.Event | None = None  # set → stop


_HEADPHONE_KEYWORDS = ["WH-", "WF-", "AirPods", "Headphones", "Headset", "Buds", "PLT", "PL focus"]
_FALLBACK_DEVICE = "MacBook Pro Speakers"

# ---------------------------------------------------------------------------
# Event-driven device caching
# ---------------------------------------------------------------------------

_devices_dirty: bool = False          # set True by CoreAudio callback on device change
_cached_chain: list[int | None] | None = None  # None = not yet built
_cached_device_name: str | None = None         # for change-log
_listener_proc_ref = None             # keeps CoreAudio callback alive (prevent GC)


def _register_device_listener() -> None:
    """Register a CoreAudio AudioObjectAddPropertyListener for device changes.

    On any device-list change the callback sets ``_devices_dirty = True``.
    The next ``_play_audio`` call will then reinitialise PortAudio and re-pick
    the best output device.

    No-op if ``pyobjc-framework-CoreAudio`` is unavailable (non-macOS or not
    installed).  Audio never breaks — we fall back to per-call detection.
    """
    global _listener_proc_ref
    try:
        from CoreAudio import (  # type: ignore[import]
            AudioObjectAddPropertyListener,
            AudioObjectPropertyAddress,
            kAudioHardwarePropertyDevices,
            kAudioObjectPropertyElementMain,
            kAudioObjectPropertyScopeGlobal,
            kAudioObjectSystemObject,
        )

        def _on_devices_changed(object_id, num_addrs, addrs, client_data) -> int:  # type: ignore[return]
            global _devices_dirty
            _devices_dirty = True
            return 0  # OSStatus OK

        addr = AudioObjectPropertyAddress(
            kAudioHardwarePropertyDevices,
            kAudioObjectPropertyScopeGlobal,
            kAudioObjectPropertyElementMain,
        )
        _listener_proc_ref = _on_devices_changed  # prevent GC of the callable
        status = AudioObjectAddPropertyListener(
            kAudioObjectSystemObject,
            addr,
            _on_devices_changed,
            None,
        )
        if status == 0:
            print("[talkback] CoreAudio device-change listener registered", file=sys.stderr)
        else:
            print(
                f"[talkback] CoreAudio listener registration returned status={status}",
                file=sys.stderr,
            )
    except Exception as exc:
        print(
            f"[talkback] CoreAudio listener unavailable ({exc!r}), using per-call detection",
            file=sys.stderr,
        )


def _device_name_str(device_idx: int | None) -> str | None:
    """Return the device name for logging, or None on any error."""
    if device_idx is None:
        return None
    try:
        return sd.query_devices(device_idx)["name"]  # type: ignore[index]
    except Exception:
        return None


def _pick_device() -> int | None:
    """Return the index of the first connected headphone output device with audio output."""
    try:
        devices = sd.query_devices()
        for idx, d in enumerate(devices):
            if d["max_output_channels"] > 0:
                for kw in _HEADPHONE_KEYWORDS:
                    if kw.lower() in d["name"].lower():
                        return idx
    except Exception:
        pass
    return None


def _find_fallback_index() -> int | None:
    """Return the index of the MacBook Pro Speakers device, or None."""
    try:
        for idx, d in enumerate(sd.query_devices()):
            if d["max_output_channels"] > 0 and d["name"] == _FALLBACK_DEVICE:
                return idx
    except Exception:
        pass
    return None


def _try_play(audio: np.ndarray, samplerate: int, device: int | str | None) -> None:
    """Attempt to play audio on the given device; raises on failure."""
    global _current_event
    with _playback_lock:
        if _current_event is not None:
            _current_event.set()
        sd.stop()
        stop_event = threading.Event()
        _current_event = stop_event

    if audio is None or len(audio) == 0:
        return

    finished = threading.Event()

    def _callback(outdata, frames, time_info, status):
        nonlocal pos
        if stop_event.is_set():
            raise sd.CallbackAbort
        chunk = audio[pos : pos + frames]
        if len(chunk) < frames:
            outdata[: len(chunk), 0] = chunk
            outdata[len(chunk) :] = 0
            raise sd.CallbackStop
        outdata[:, 0] = chunk
        pos += frames

    pos = 0
    _MAX_RETRIES = 3
    _RETRY_DELAY = 0.5
    for attempt in range(_MAX_RETRIES):
        stream = None
        try:
            stream = sd.OutputStream(
                samplerate=samplerate,
                channels=1,
                dtype="float32",
                device=device,
                callback=_callback,
                finished_callback=finished.set,
            )
            stream.start()
            break
        except Exception as e:
            if stream is not None:
                try:
                    stream.close()
                except Exception:
                    pass
            err = str(e)
            if ("-9986" in err or "Internal PortAudio error" in err) and attempt < _MAX_RETRIES - 1:
                time.sleep(_RETRY_DELAY)
                continue
            raise
    if attempt > 0:
        print(f"[talkback] device {device!r} recovered after {attempt + 1} attempt(s)", file=sys.stderr)
    finished.wait()
    stream.stop()
    stream.close()


def _play_audio(audio: np.ndarray, samplerate: int = 24000) -> None:
    """Play audio array with device fallback chain, respecting cancellation.

    Device selection is event-driven:
    - On first call or when ``_devices_dirty`` is True (CoreAudio notified a
      device change): reinitialise PortAudio (dirty only), re-pick the best
      output device, cache the resulting chain, and clear the flag.
    - On subsequent clean calls: reuse the cached chain — zero steady-state cost.

    Falls back to per-call detection if PortAudio reinit fails, so audio never
    stops working even if the reinit path errors.
    """
    global _devices_dirty, _cached_chain, _cached_device_name, _current_event

    if _cached_chain is None or _devices_dirty:
        try:
            if _devices_dirty:
                # Cancel any active stream under the lock before reinit.
                with _playback_lock:
                    if _current_event is not None:
                        _current_event.set()
                    sd.stop()
                    _current_event = None
                # Reinit PortAudio so it enumerates devices connected since startup.
                sd._terminate()
                sd._initialize()

            # (Re-)detect device chain.
            primary = _pick_device()
            fallback = _find_fallback_index()
            new_chain: list[int | None] = []
            if primary is not None:
                new_chain.append(primary)
            if fallback is not None and fallback != primary:
                new_chain.append(fallback)
            if not new_chain:
                new_chain.append(None)  # let PortAudio pick default

            # Log when the chosen device changes.
            new_name = _device_name_str(primary)
            if new_name != _cached_device_name:
                print(
                    f"[talkback] device: {_cached_device_name!r} → {new_name!r}",
                    file=sys.stderr,
                )
                _cached_device_name = new_name

            _cached_chain = new_chain
            _devices_dirty = False
            chain = new_chain

        except Exception as exc:
            # Fallback: detect per-call (original behaviour), don't touch cache.
            print(
                f"[talkback] PortAudio reinit failed ({exc}), falling back to per-call detection",
                file=sys.stderr,
            )
            primary = _pick_device()
            fallback = _find_fallback_index()
            chain = []
            if primary is not None:
                chain.append(primary)
            if fallback is not None and fallback != primary:
                chain.append(fallback)
            if not chain:
                chain.append(None)
    else:
        chain = _cached_chain

    for dev in chain:
        try:
            _try_play(audio, samplerate, dev)
            return
        except Exception as e:
            print(f"[talkback] device {dev!r} failed ({e}), trying next...", file=sys.stderr)

    print("[talkback] ERROR: all audio devices failed", file=sys.stderr)


def cancel_playback() -> None:
    """Cancel current playback immediately."""
    global _current_event
    with _playback_lock:
        if _current_event is not None:
            _current_event.set()
        sd.stop()
        _current_event = None


# ---------------------------------------------------------------------------
# TTS engine (lazy-loaded)
# ---------------------------------------------------------------------------
_pipeline = None


def _get_pipeline():
    global _pipeline
    if _pipeline is None:
        from kokoro import KPipeline
        _pipeline = KPipeline(lang_code="a")
    return _pipeline


def synthesize(text: str, voice: str = "af_heart", speed: float = 1.0) -> np.ndarray | None:
    """Synthesize text to a numpy audio array."""
    pipe = _get_pipeline()
    chunks = []
    for _graphemes, _phonemes, audio in pipe(text, voice=voice, speed=speed):
        if audio is not None:
            chunks.append(audio)
    if not chunks:
        return None
    return np.concatenate(chunks)


def speak(text: str, voice: str = "af_heart", speed: float = 1.0) -> None:
    """Synthesize and play text. Cancels any ongoing playback first."""
    if not text.strip():
        cancel_playback()
        return
    audio = synthesize(text, voice=voice, speed=speed)
    if audio is not None:
        _play_audio(audio)


# ---------------------------------------------------------------------------
# HTTP server (Flask)
# ---------------------------------------------------------------------------

def create_app(voice: str = "af_heart", speed: float = 1.0):
    from flask import Flask, request, jsonify

    app = Flask(__name__)

    @app.route("/health", methods=["GET"])
    def health():
        return jsonify({"status": "ok"})

    @app.route("/speak", methods=["POST"])
    def handle_speak():
        data = request.get_json(silent=True) or {}
        text = data.get("text", "")
        req_speed = data.get("speed", speed)
        req_voice = data.get("voice", voice)
        client_ip = request.remote_addr or ""

        _log_speak(text, req_voice, req_speed, client_ip)

        if not text.strip():
            cancel_playback()
            return jsonify({"status": "cancelled"})

        t = threading.Thread(
            target=speak,
            args=(text,),
            kwargs={"voice": req_voice, "speed": req_speed},
            daemon=True,
        )
        t.start()
        return jsonify({"status": "speaking"})

    return app


def run_server(port: int, voice: str, speed: float) -> None:
    app = create_app(voice=voice, speed=speed)
    _register_device_listener()
    print(f"[talkback] Loading Kokoro model...")
    _get_pipeline()
    print(f"[talkback] Listening on http://localhost:{port} (auto device)")
    app.run(host="127.0.0.1", port=port, threaded=True)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(description="Talkback TTS service")
    parser.add_argument("text", nargs="?", default=None, help="Text to speak (CLI mode)")
    parser.add_argument("--listen", type=int, default=None, metavar="PORT",
                        help="Start HTTP server on PORT (default: 18787)")
    parser.add_argument("--speed", type=float, default=1.0, help="Speech speed (default: 1.0)")
    parser.add_argument("--voice", type=str, default="af_heart", help="Voice ID (default: af_heart)")
    parser.add_argument("--list-devices", action="store_true", help="List available audio output devices and exit")
    args = parser.parse_args()

    if args.list_devices:
        print(sd.query_devices())
        sys.exit(0)

    if args.listen is not None:
        run_server(port=args.listen, voice=args.voice, speed=args.speed)
    elif args.text:
        speak(args.text, voice=args.voice, speed=args.speed)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
